generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  role            Role
  name            String
  avatarUrl       String?          @map("avatar_url")
  createdAt       DateTime         @default(now()) @map("created_at")
  teacher         Teacher?
  conversionFeedback ConversionFeedback?
  referral        Referral?        @relation("Ambassador")
  referredById    String?          @map("referral_id") @db.Uuid
  referredBy      Referral?        @relation("Usage", fields: [referredById], references: [id])
  
  @@map("users")
}

model Referral {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique
  userId      String?  @unique @map("user_id")
  useCount    Int      @default(0) @map("use_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  user        User?    @relation("Ambassador", fields: [userId], references: [id], onDelete: SetNull)
  usersReferred User[]  @relation("Usage")

  @@map("referrals")
}

model Teacher {
  id                    String           @id @default(uuid())
  userId                String           @unique @map("user_id")
  schoolId              String           @map("school_id")
  phone                 String?
  createdAt             DateTime         @default(now()) @map("created_at")
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  school                School           @relation(fields: [schoolId], references: [id])
  assessments           Assessment[]
  lessons               Lesson[]
  quizzes               Quiz[]
  feedbacks             Feedback[]

  @@map("teachers")
}

model School {
  id        String    @id @default(uuid())
  name      String
  teachers  Teacher[]

  @@map("schools")
}

model Lesson {
  id               String          @id @default(uuid())
  teacherId        String          @map("teacher_id")
  title            String
  status           LessonStatus    @default(draft)
  createdAt        DateTime        @default(now()) @map("created_at")
  teacher          Teacher         @relation(fields: [teacherId], references: [id])

  @@map("lessons")
}

model Quiz {
  id               String          @id @default(uuid())
  teacherId        String          @map("teacher_id")
  title            String
  status           QuizStatus      @default(draft)
  createdAt        DateTime        @default(now()) @map("created_at")
  teacher          Teacher         @relation(fields: [teacherId], references: [id])

  @@map("quizzes")
}

model Assessment {
  id               String                   @id @default(uuid())
  teacherId        String                   @map("teacher_id")
  title            String
  status           QuizStatus               @default(draft)
  isWorksheet      Boolean                  @default(false) @map("is_worksheet")
  createdAt        DateTime                 @default(now()) @map("created_at")
  teacher          Teacher                  @relation(fields: [teacherId], references: [id])

  @@map("assessments")
}

enum Role {
  teacher
  student
  admin
}

enum LessonStatus {
  draft
  saved
  published
  generated
}

enum QuizStatus {
  draft
  saved
  published
  generated
}

enum AssignedTo {
  NONE
  SUVANSH
  PRIYANA
  CALLER_A
  CALLER_B
}

model Feedback {
  id            String               @id @default(uuid())
  teacherId     String               @map("teacher_id")
  promptKind    String               @default("manual") @map("prompt_kind")
  rating        Int?
  message       String?
  createdAt     DateTime             @default(now()) @map("created_at")
  artifactType  String?              @map("artifact_type")
  artifactId    String?              @map("artifact_id")
  teacher       Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("feedback")
}

model ConversionFeedback {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String      @unique @map("user_id")
  feedback   String
  assignedTo AssignedTo  @default(NONE) @map("assigned_to")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("conversion_feedback")
}

